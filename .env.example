# ============================================
# RunRouteAI — Variables d'environnement
# ============================================
# Copie ce fichier en .env.local et remplis tes clés

# OpenAI API (optionnel — pour les résumés IA)
# Obtenir une clé : https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# OpenRouteService API (gratuit, 2000 req/jour)
# Obtenir une clé : https://openrouteservice.org/dev/#/signup
OPENROUTESERVICE_API_KEY=eyJ...

# Mode demo (true = données mock, false = vraies APIs)
NEXT_PUBLIC_DEMO_MODE=false
